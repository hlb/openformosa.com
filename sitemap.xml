---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% assign pages = site.pages | where_exp: "page", "page.layout" | where_exp: "page", "page.url != '/sitemap.xml'" | where_exp: "page", "page.url != '/feed.xml'" | where_exp: "page", "page.url != '/robots.txt'" | where_exp: "page", "page.url != '/404/'" | where_exp: "page", "page.url != '/404.html'" %}
  {% for page in pages %}
    {% unless page.url contains '/assets/' or page.url contains '/404.html' %}
  <url>
    <loc>{{ page.url | absolute_url | xml_escape }}</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
  </url>
    {% endunless %}
  {% endfor %}
  {% for post in site.posts %}
  <url>
    <loc>{{ post.url | absolute_url | xml_escape }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
  </url>
  {% endfor %}
</urlset>
