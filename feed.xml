---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title | xml_escape }}</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <link href="{{ '/feed.xml' | absolute_url | xml_escape }}" rel="self" type="application/atom+xml"/>
  <link href="{{ '/' | absolute_url | xml_escape }}" rel="alternate" type="text/html"/>
  <id>{{ '/' | absolute_url | xml_escape }}</id>
  <updated>{{ site.posts.first.date | default: site.time | date_to_xmlschema }}</updated>
  {% for post in site.posts limit: 20 %}
  <entry>
    <title>{{ post.title | xml_escape }}</title>
    <link href="{{ post.url | absolute_url | xml_escape }}" rel="alternate" type="text/html"/>
    <id>{{ post.url | absolute_url | xml_escape }}</id>
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</updated>
    <summary>{{ post.description | default: site.description | xml_escape }}</summary>
  </entry>
  {% endfor %}
</feed>
